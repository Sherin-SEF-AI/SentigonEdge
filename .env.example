# Sentigon V2 environment template. Copy to .env and adjust. No real secrets here.

APP_ENV=dev
LOG_LEVEL=info
LOG_JSON=true

POSTGRES_USER=sentigon
POSTGRES_PASSWORD=change_me
POSTGRES_DB=sentigon
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://sentigon:change_me@localhost:5433/sentigon
DATABASE_URL_SYNC=postgresql+psycopg2://sentigon:change_me@localhost:5433/sentigon

REDIS_URL=redis://localhost:6380/0

KAFKA_BOOTSTRAP=localhost:19093
KAFKA_CLIENT_ID=sentigon

QDRANT_URL=http://localhost:6335
QDRANT_GRPC_PORT=6336

MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=sentigon
MINIO_SECRET_KEY=change_me
MINIO_SECURE=false
MINIO_BUCKET_RECORDINGS=recordings
MINIO_BUCKET_CLIPS=clips
MINIO_BUCKET_SNAPSHOTS=snapshots
MINIO_BUCKET_EVIDENCE=evidence

MEDIAMTX_API=http://localhost:9997
MEDIAMTX_RTSP=rtsp://localhost:8554
MEDIAMTX_WEBRTC=http://localhost:8889
MEDIAMTX_HLS=http://localhost:8888

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
DEFAULT_ADMIN_EMAIL=admin@sentigon.local
DEFAULT_ADMIN_PASSWORD=

# Bind address for every service HTTP server. Secure default is 127.0.0.1 (front
# the services with an authenticated reverse proxy). Set 0.0.0.0 only if the box
# is on a trusted network — services now authenticate reads, so it is far less
# exposed than before, but ingest/perception reads stay open for live video.
SERVICE_BIND_HOST=127.0.0.1
# Browser console origin(s), comma-separated. Never "*" outside dev.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3002
# Set APP_ENV=production to hard-fail startup on any weak/default secret above.

REASON_BACKEND=vllm
REASON_MODEL=Qwen/Qwen3-VL-8B-Instruct
REASON_ENDPOINT=http://localhost:8050/v1
TRITON_URL=localhost:8001

# Open-vocabulary grounding ("find and box it"). Localizes NL alerts instead of a
# bare yes/no and powers the on-demand POST /ground endpoint.
#   backend=vlm            -> reuse the reason VLM (default; a license you can ship)
#   backend=locateanything -> a LocateAnything server (scripts/locateanything_server.py;
#                             NVIDIA LocateAnything-3B is NON-COMMERCIAL / research-only)
# ground_endpoint/model blank => fall back to the reason endpoint/model.
REASON_SVC_GROUND_ENABLED=true
REASON_SVC_GROUND_BACKEND=vlm
REASON_SVC_GROUND_ENDPOINT=
REASON_SVC_GROUND_MODEL=
REASON_SVC_GROUND_MAX_BOXES=12
REASON_SVC_GROUND_MIN_SCORE=0.3

API_PORT=8010
INGEST_PORT=8020
PERCEPTION_PORT=8030
CONTEXT_PORT=8040
REASON_PORT=8050
SEARCH_PORT=8060
NOTIFY_PORT=8070
GOVERNANCE_PORT=8075
WEB_PORT=3001
