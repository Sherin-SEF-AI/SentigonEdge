# Sentigon V2 environment template. Copy to .env and adjust. No real secrets here.

APP_ENV=dev
LOG_LEVEL=info
LOG_JSON=true

POSTGRES_USER=sentigon
POSTGRES_PASSWORD=change_me
POSTGRES_DB=sentigon
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://sentigon:change_me@localhost:5433/sentigon
DATABASE_URL_SYNC=postgresql+psycopg2://sentigon:change_me@localhost:5433/sentigon

REDIS_URL=redis://localhost:6380/0

KAFKA_BOOTSTRAP=localhost:19093
KAFKA_CLIENT_ID=sentigon

QDRANT_URL=http://localhost:6335
QDRANT_GRPC_PORT=6336

MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=sentigon
MINIO_SECRET_KEY=change_me
MINIO_SECURE=false
MINIO_BUCKET_RECORDINGS=recordings
MINIO_BUCKET_CLIPS=clips
MINIO_BUCKET_SNAPSHOTS=snapshots
MINIO_BUCKET_EVIDENCE=evidence

MEDIAMTX_API=http://localhost:9997
MEDIAMTX_RTSP=rtsp://localhost:8554
MEDIAMTX_WEBRTC=http://localhost:8889
MEDIAMTX_HLS=http://localhost:8888

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
DEFAULT_ADMIN_EMAIL=admin@sentigon.local
DEFAULT_ADMIN_PASSWORD=

REASON_BACKEND=vllm
REASON_MODEL=Qwen/Qwen3-VL-8B-Instruct
REASON_ENDPOINT=http://localhost:8050/v1
TRITON_URL=localhost:8001

API_PORT=8010
INGEST_PORT=8020
PERCEPTION_PORT=8030
CONTEXT_PORT=8040
REASON_PORT=8050
SEARCH_PORT=8060
NOTIFY_PORT=8070
GOVERNANCE_PORT=8075
WEB_PORT=3001
